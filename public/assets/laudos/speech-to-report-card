 += 5) {\n      const y = L.cy + this.waveY(x, ts * speed, A);\n      if (!started) { ctx.moveTo(x, y); started = true; } else ctx.lineTo(x, y);\n    }\n    ctx.stroke();\n\n    // page outline\n    const pulse = this.completing ? Math.sin(Math.min(1, this.completeT / 500) * Math.PI) : 0;\n    ctx.strokeStyle = pulse > 0 ? this.mix([224, 215, 202], acc, pulse * 0.9) : 'rgb(224,215,202)';\n    ctx.lineWidth = 1;\n    ctx.beginPath();\n    ctx.roundRect(L.page.x, L.page.y, L.page.w, L.page.h, 8);\n    ctx.stroke();\n    if (pulse > 0.05) {\n      ctx.globalAlpha = pulse;\n      ctx.fillStyle = 'rgb(' + acc.join(',') + ')';\n      ctx.beginPath();\n      ctx.arc(L.page.x + L.page.w - 12, L.page.y + 12, 3, 0, Math.PI * 2);\n      ctx.fill();\n      ctx.globalAlpha = 1;\n    }\n\n    // dashes\n    for (let i = 0; i < L.slots.length; i++) {\n      const d = this.dashes[i];\n      if (!d) continue;\n      const s = L.slots[i];\n      let a = 1;\n      if (this.completing) a = 1 - this.clamp((this.completeT - 500 - s.row * 90) / 280, 0, 1);\n      if (a <= 0) continue;\n      const grow = this.sstep(0, 1, Math.min(1, (ts - d.born) / 220));\n      const fl = Math.min(1, (ts - d.born) / 320);\n      const base = s.title ? dashTitle : dashBody;\n      ctx.fillStyle = this.mix(acc, base, fl);\n      ctx.globalAlpha = a * 0.92;\n      const w = (s.title ? 6.2 : 4.6) * grow;\n      const h = s.title ? 2.2 : 1.6;\n      ctx.beginPath();\n      ctx.roundRect(s.x, s.y - h / 2, Math.max(0.8, w), h, h / 2);\n      ctx.fill();\n    }\n    ctx.globalAlpha = 1;\n\n    // gate dotted line\n    ctx.fillStyle = 'rgb(207,197,182)';\n    for (let y = 6; y < L.H - 28; y += 7) {\n      ctx.globalAlpha = 0.55;\n      ctx.beginPath();\n      ctx.arc(L.gateX, y, 0.9, 0, Math.PI * 2);\n      ctx.fill();\n    }\n    ctx.globalAlpha = 1;\n\n    // gate glow\n    if (this.glow > 0.02) {\n      ctx.save();\n      ctx.shadowColor = accent;\n      ctx.shadowBlur = 10;\n      ctx.globalAlpha = Math.min(1, this.glow) * 0.9;\n      ctx.fillStyle = 'rgb(' + acc.join(',') + ')';\n      ctx.fillRect(L.gateX - 0.75, L.cy - 9, 1.5, 18);\n      ctx.restore();\n      ctx.globalAlpha = 1;\n    }\n\n    // gate status dot\n    ctx.fillStyle = 'rgb(' + acc.join(',') + ')';\n    ctx.globalAlpha = 0.5 + 0.5 * Math.min(1, this.glow);\n    ctx.beginPath();\n    ctx.arc(L.gateX, 8, 2.6 + 0.9 * Math.min(1, this.glow), 0, Math.PI * 2);\n    ctx.fill();\n    ctx.globalAlpha = 1;\n\n    // particles\n    for (const p of this.particles) {\n      let col, r = 1.4, al = 0.9;\n      if (p.state === 0) {\n        const nearG = this.clamp(1 - (L.gateX - p.x) / 60, 0, 1);\n        col = this.mix(ink, acc, nearG * nearG);\n        r = 1.4 + 0.5 * nearG;\n      } else if (p.state === 1) {\n        const e = Math.min(1, p.prog);\n        col = this.mix(acc, dashBody, e);\n        r = 1.6 - 0.3 * e;\n      } else {\n        col = 'rgb(' + acc.join(',') + ')';\n        al = 0.9 * Math.max(0, p.alpha);\n      }\n      ctx.fillStyle = col;\n      ctx.globalAlpha = al;\n      ctx.beginPath();\n      ctx.arc(p.x, p.y, r, 0, Math.PI * 2);\n      ctx.fill();\n    }\n    ctx.globalAlpha = 1;\n  }\n\n  renderVals() {\n    this.startLoop();\n    return {\n      canvasRef: this.canvasRef,\n      wrapRef: this.wrapRef,\n      dotRef: this.dotRef,\n      showLabels: this.props.showLabels ?? true,\n      onMove: (e) => {\n        const r = this.wrapRef.current.getBoundingClientRect();\n        this.mouse = { x: e.clientX - r.left, y: e.clientY - r.top, inside: true };\n        if (performance.now() - (this._lastTick || 0) > 80) this.tick(performance.now());\n      },\n      onLeave: () => { this.mouse.inside = false; },\n      onDown: () => { this.burst = 1; }\n    };\n  }\n}\n<\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"
  </script>
